# PostgreSQL（必填）
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# 管理端 JWT（必填，生产请用长随机串）
ADMIN_JWT_SECRET="CHANGE_ME_TO_RANDOM"

# 浏览器访问前端的 Origin（CORS / Cookie）
WEB_ORIGIN="http://localhost:3000"

# API 监听端口（可选，默认 8787）
API_PORT=8787

# DeepSeek：在线 AI 咨询（可选；不配置则使用关键词匹配 + 兜底回复）
DEEPSEEK_API_KEY=""

# 前端直连 API 时用（开发环境通常可省略，Vite 已代理 /api）
# VITE_API_BASE="http://localhost:8787"
